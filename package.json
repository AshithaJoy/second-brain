{
  "name": "second-brain",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "all": "concurrently \"npm run dev\" \"npm run dev --prefix ../second-brain-backend\"",
    "test:e2e": "playwright test",
    "test": "npm run lint",
    "test:full": "npm run test && npm run test:e2e && node scripts/generate_test_report.js",
    "start": "serve -s dist"
  },
  "dependencies": {
    "serve": "^14.2.0",
    "@react-oauth/google": "^0.13.5",
    "axios": "^1.16.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
